{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lan Input Sync",
  "version": "0.1.0",
  "identifier": "com.robin.lan-input-sync",
  "build": {
    "beforeDevCommand": "npm run dev --prefix ..",
    "beforeBuildCommand": "npm run build --prefix ..",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Lan Input Sync",
        "width": 980,
        "height": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
