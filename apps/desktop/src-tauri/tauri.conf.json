{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lan Input Sync",
  "version": "0.1.0",
  "identifier": "com.robin.lan-input-sync",
  "build": {
    "beforeDevCommand": {
      "script": "npm run dev",
      "cwd": ".."
    },
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Lan Input Sync",
        "width": 980,
        "height": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
